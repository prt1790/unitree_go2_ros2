<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- Unitree 4D LiDAR L1 — matched to real specs:
         FOV: 360° horizontal x 90° vertical
         Range: 0.05m - 30m
         Samples: 600 horizontal x 90 vertical (~real density)
         Rate: 11Hz (real circumferential scan frequency)
         Noise: gaussian stddev 0.02m (matches ±2cm accuracy spec) -->

    <link name="lidar_l1_link">
        <inertial>
            <mass value="0.27"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find unitree_go2_description)/meshes/L1_4D_Lidar.dae" scale="1 1 1"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.07"/>
            </geometry>
        </collision>
    </link>

    <joint name="lidar_l1_joint" type="fixed">
        <parent link="trunk"/>
        <child link="lidar_l1_link"/>
        <!-- Mounted on top-centre of trunk, slightly forward -->
        <origin rpy="0 0 0" xyz="0.05 0.0 0.12"/>
    </joint>

    <gazebo reference="lidar_l1_link">
        <sensor name="lidar_l1" type="gpu_lidar">
            <topic>unitree_lidar</topic>
            <update_rate>11</update_rate>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>600</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>90</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.785398</min_angle>
                        <max_angle>0.785398</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.05</min>
                    <max>30.0</max>
                    <resolution>0.02</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.02</stddev>
                </noise>
            </lidar>
            <visualize>false</visualize>
            <gz_frame_id>lidar_l1_link</gz_frame_id>
            <always_on>1</always_on>
        </sensor>
    </gazebo>
</robot>
